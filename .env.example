# Copy to .env.local for development and set these in your host (e.g. Vercel) for production.

# --- Resend (https://resend.com/api-keys) ---
RESEND_API_KEY=re_xxxxxxxx

# Verified sender in Resend (use onboarding@resend.dev only for tests)
RESEND_FROM_EMAIL="Maria's Design Studio <onboarding@resend.dev>"

# Where contact form emails should arrive
CONTACT_TO_EMAIL=you@example.com

# --- Cloudflare Turnstile (https://dash.cloudflare.com/?to=/:account/turnstile) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAxxxxxxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAxxxxxxxxxxxxxxxxxxxx

# Optional: comma-separated allowed Origin header values (defaults include mariasdesignstudio.ca + localhost)
# CONTACT_ALLOWED_ORIGINS=https://mariasdesignstudio.ca,https://www.mariasdesignstudio.ca,http://localhost:3000
